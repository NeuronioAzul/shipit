{
  "name": "shipit",
  "version": "1.0.0",
  "description": "Automatize a criação do Relatório Mensal de Atividades Desenvolvidas seguindo o padrão institucional do MEC.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -n vite,electron \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeuronioAzul/shipit.git"
  },
  "keywords": [
    "electron",
    "react",
    "report",
    "mec",
    "pdf"
  ],
  "author": "NeuronioAzul",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/NeuronioAzul/shipit/issues"
  },
  "homepage": "https://github.com/NeuronioAzul/shipit#readme",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@xmldom/xmldom": "^0.9.9",
    "better-sqlite3": "^12.8.0",
    "jszip": "^3.10.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "reflect-metadata": "^0.2.2",
    "sonner": "^2.0.7",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "sql.js": "^1.14.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.3",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.neuronioazul.shipit",
    "productName": "ShipIt!",
    "copyright": "Copyright © 2026 NeuronioAzul",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "assets/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "docs/Relatórios 2026/RELATÓRIO DE SERVIÇO - TEMPLATE.docx",
        "to": "RELATÓRIO DE SERVIÇO - TEMPLATE.docx"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/images/icons/ms-icon-310x310.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/images/icons/apple-icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/images/icons",
      "category": "Office"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ]
  }
}
